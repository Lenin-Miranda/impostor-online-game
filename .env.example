# ─────────────────────────────────────────────────────────────
# Variables compartidas por docker-compose (raíz del monorepo)
# Copia este archivo a `.env` y rellena los valores.
#
# Para Supabase local: ejecuta `npx supabase start` y usa las
# claves que imprime en consola (API URL, anon key, service_role).
# ─────────────────────────────────────────────────────────────

# --- Backend (NestJS) ---
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
